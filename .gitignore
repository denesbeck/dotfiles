# ignore everything
*

# unignore core files
!.gitignore
!README.md
!init.yml

# unignore config.fish
!fish
!fish/config.fish

# unignore nvim folder with subdirs
!nvim
!nvim/*
!nvim/**

# ignore lazylock.json
nvim/lazy-lock.json

# ignore machine-local Claude Code settings
nvim/.claude/settings.local.json

# unignore tmux.conf
!tmux
!tmux/tmux.conf
